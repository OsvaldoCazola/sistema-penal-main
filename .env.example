# ============================================================
#  SISTEMA DE DIREITO PENAL ANGOLANO — variáveis de ambiente
#  Copie para .env e preencha os valores reais.
#  O ficheiro .env NUNCA deve ser commitado no Git.
# ============================================================

# ── Profile ─────────────────────────────────────────────────
# h2        → desenvolvimento local (sem PostgreSQL, sem Redis)
# default   → produção com PostgreSQL
SPRING_PROFILE=h2

# ── Base de dados PostgreSQL ─────────────────────────────────
# Necessário apenas com SPRING_PROFILE=default
DB_URL=jdbc:postgresql://postgres:5432/sistema_penal
DB_USERNAME=postgres
DB_PASSWORD=ALTERE_ESTA_SENHA_FORTE_EM_PRODUCAO
DB_POOL_MAX=10
DB_POOL_MIN=3

# ── JWT ──────────────────────────────────────────────────────
# Gerar com:
#   python3 -c "import secrets,base64; print(base64.b64encode(secrets.token_bytes(32)).decode())"
JWT_SECRET=GERE_UM_SECRET_SEGURO_AQUI
JWT_EXPIRATION=3600000
JWT_REFRESH_EXPIRATION=604800000

# ── Groq API ─────────────────────────────────────────────────
# Obter em: https://console.groq.com/keys
# Se não definida, chat/IA retorna mensagem de "não disponível" sem crash.
GROQ_API_KEY=gsk_SUA_CHAVE_GROQ_AQUI

# ── Senhas dos utilizadores iniciais ─────────────────────────
# Obrigatórias em produção (SPRING_PROFILE=default)
ADMIN_PASSWORD=Admin@2024Seguro!
JUIZ_PASSWORD=Juiz@2024Seguro!
PROCURADOR_PASSWORD=Proc@2024Seguro!
ADVOGADO_PASSWORD=Adv@2024Seguro!
ESTUDANTE_PASSWORD=Est@2024Seguro!

# ── CORS ─────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000

# ── Swagger ──────────────────────────────────────────────────
# true em desenvolvimento, false em produção
SWAGGER_ENABLED=true

# ── Email (opcional) ─────────────────────────────────────────
# MAIL_HOST=smtp.gmail.com
# MAIL_PORT=587
# MAIL_USERNAME=seu_email@gmail.com
# MAIL_PASSWORD=sua_senha_de_app_gmail

# ── Servidor ─────────────────────────────────────────────────
# SERVER_PORT=8080
# TOMCAT_MAX_THREADS=200

# ── Logs ─────────────────────────────────────────────────────
# LOG_FILE=logs/sistema-penal.log
