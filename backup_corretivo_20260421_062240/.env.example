# ============================================================
#  SISTEMA DE DIREITO PENAL ANGOLANO — variáveis de ambiente
#  Copie este ficheiro para .env e preencha os valores reais.
#  O ficheiro .env NUNCA deve ser commitado no repositório.
# ============================================================

# ── Spring Profile ───────────────────────────────────────────
# Use 'h2' para desenvolvimento local sem PostgreSQL
# Use 'default' (ou deixe em branco) para PostgreSQL em produção
SPRING_PROFILE=h2

# ── Banco de Dados PostgreSQL ────────────────────────────────
# Necessário apenas com SPRING_PROFILE=default
DB_URL=jdbc:postgresql://localhost:5432/sistema_penal
DB_USERNAME=postgres
DB_PASSWORD=ALTERE_ESTA_SENHA_EM_PRODUCAO

# ── JWT Secret ───────────────────────────────────────────────
# Gere um valor seguro com o comando:
#   openssl rand -base64 32
# ou (Python):
#   python3 -c "import secrets,base64; print(base64.b64encode(secrets.token_bytes(32)).decode())"
JWT_SECRET=GERE_UM_SECRET_SEGURO_E_COLOQUE_AQUI

# ── Groq API Key ─────────────────────────────────────────────
# Obtenha em: https://console.groq.com/keys
# ⚠️  Revogue a chave antiga se ela foi exposta no repositório.
GROQ_API_KEY=gsk_SUA_NOVA_CHAVE_AQUI

# ── Redis ────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ── CORS (separados por vírgula) ─────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ── Email (opcional) ─────────────────────────────────────────
# MAIL_USERNAME=seu_email@gmail.com
# MAIL_PASSWORD=sua_senha_de_app_gmail
